{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run query_machine.py",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.yafi-venv/Scripts/python.exe",
      "program": "${workspaceFolder}/yafi/query_machine.py",
      "cwd": "${workspaceFolder}/yafi",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Run query_machine.py (custom config)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.yafi-venv/Scripts/python.exe",
      "program": "${workspaceFolder}/yafi/query_machine.py",
      "args": ["${input:configFileName}"],
      "cwd": "${workspaceFolder}/yafi",
      "console": "integratedTerminal",
      "justMyCode": true
    },
      "cwd": "${workspaceFolder}/yafi",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ],
  "inputs": [
    {
      "id": "configFileName",
      "type": "promptString",
      "description": "Filename to query config JSON (relative to yafi/configs, e.g. query_config.json)",
      "default": "query_config.json"
    }
  ]
}
